# ============================================================
# General
# ============================================================
LOG_LEVEL=info
APP_API_KEY=change-me-before-deployment

# ============================================================
# Paperless-ngx
# ============================================================
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=your-paperless-api-token-here
PAPERLESS_TIMEOUT=30

# ============================================================
# Qdrant
# ============================================================
QDRANT_BASE_URL=http://qdrant:6333
QDRANT_COLLECTION=paperless_docs
QDRANT_TIMEOUT=30
QDRANT_API_KEY=your-qdrant-api-key-here
RAG_QDRANT_TOP_K=30

# ============================================================
# LLM (embedding + chat via Ollama or compatible backend)
# ============================================================
LLM_ENGINE=ollama
LLM_OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL_EMBEDDING=nomic-embed-text
LLM_MODEL_CHAT=llama3.2
LLM_MODEL_VISION=qcwind/qwen3-vl-8B-Q4_K_M          # Ollama Vision model for OCR
LLM_MODEL_EMBEDDING_MAX_CHARS=2048
LLM_TIMEOUT=240

# ============================================================
# Cache (filter option cache for LLM classification enrichment)
# ============================================================
CACHE_ENGINE=redis
CACHE_REDIS_BASE_URL=redis://redis:6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DB=0
CACHE_REDIS_DEFAULT_TTL_SECONDS=86400

# ============================================================
# User Identity Mapping
# ============================================================
USER_MAPPING_FILE=config/user_mapping.yml

# ============================================================
# FastAPI Server
# ============================================================
API_SERVER_API_KEY=your-secret-key

# ============================================================
# Document Ingestion Service
# ============================================================
DOC_INGESTION_OWNER_ID=3                  # Default DMS owner_id for uploaded documents
DOC_INGESTION_LANGUAGE=German             # Language for LLM-generated metadata (document_type, tags)

# ============================================================
# OCR Service
# ============================================================
OCR_ENGINE=Docling
OCR_DOCLING_BASE_URL=http://192.168.2.200:5001
OCR_DOCLING_API_KEY=                      # optional
OCR_TIMEOUT=300                            # seconds; OCR is slow, default 300
